// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AvatarImageType {
  User
  Model
}

enum AvatarVideoStatus {
  Pending
  Done
  Error
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  avatars  Avatar[]
  avatarVideos AvatarVideo[]
  createdAt DateTime @default(now())
}

model Avatar {
  id     String @id @default(uuid())
  userId String
  name   String
  prompt String @default("")
  createdAt DateTime @default(now())
  avatarImages AvatarImage[]
  avatarVideoReferences avatarVideoReferences[]
  user  User @relation(fields: [userId], references: [id])
}

model AvatarImage {
  id       String @id @default(uuid())
  avatarId String
  type     AvatarImageType
  url      String
  avatar Avatar @relation(fields: [avatarId], references: [id])
}


model AvatarVideo {
  id         String  @id @default(uuid())
  userId     String
  prompt     String
  startFrame String?
  endFrame   String?
  duration   Int
  width      Int
  height     Int
  status     AvatarVideoStatus
  user   User @relation(fields: [userId], references: [id])
  avatarVideoReferences avatarVideoReferences[]
}


model avatarVideoReferences {
  id            String @id @default(uuid())
  avatarVideoId String
  avatar        Avatar @relation(fields: [avatarId], references: [id])
  avatarId      String
  avatarVideo   AvatarVideo @relation(fields: [avatarVideoId], references: [id])
}
